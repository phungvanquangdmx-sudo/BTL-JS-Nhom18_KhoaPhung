<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Thanh Toán - TechStore</title>
  <link rel="icon" type="image/png" href="/images/favicon.png">
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-gray-50">
  <%- include('../partials/navbar') %>

  <div class="max-w-7xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold mb-8">Thanh Toán</h1>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Checkout Form -->
      <div class="lg:col-span-2">
        <form action="/checkout" method="POST" class="space-y-6">
          <!-- Shipping Information -->
          <div class="bg-white rounded-lg shadow p-6">
            <h2 class="text-2xl font-bold mb-6">Thông Tin Giao Hàng</h2>

            <div class="space-y-4">
              <div>
                <label class="block font-bold mb-2">Địa Chỉ Giao Hàng</label>
                <input type="text" 
                       name="address" 
                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-red-500"
                       required>
              </div>

              <div class="grid grid-cols-2 gap-4">
                <div>
                  <label class="block font-bold mb-2">Thành Phố</label>
                  <input type="text" 
                         name="city" 
                         class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-red-500"
                         required>
                </div>

                <div>
                  <label class="block font-bold mb-2">Tỉnh</label>
                  <input type="text" 
                         name="state" 
                         class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-red-500"
                         required>
                </div>
              </div>

              <div>
                <label class="block font-bold mb-2">Mã Bưu Chính</label>
                <input type="text" 
                       name="zipcode" 
                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-red-500"
                       required>
              </div>
            </div>
          </div>

          <!-- Payment Method -->
          <div class="bg-white rounded-lg shadow p-6">
            <h2 class="text-2xl font-bold mb-6">Phương Thức Thanh Toán</h2>

            <div class="space-y-3">
              <label class="flex items-center p-4 border border-red-300 rounded-lg cursor-pointer">
                <input type="radio" name="payment" value="card" checked class="w-4 h-4">
                <span class="ml-3 font-bold">Thẻ Tín Dụng/Thẻ Ghi Nợ</span>
              </label>

              <label class="flex items-center p-4 border border-gray-300 rounded-lg cursor-pointer hover:border-red-300">
                <input type="radio" name="payment" value="paypal" class="w-4 h-4">
                <span class="ml-3 font-bold">PayPal</span>
              </label>

              <label class="flex items-center p-4 border border-gray-300 rounded-lg cursor-pointer hover:border-red-300">
                <input type="radio" name="payment" value="bank" class="w-4 h-4">
                <span class="ml-3 font-bold">Chuyển Khoản Ngân Hàng</span>
              </label>
            </div>
          </div>

          <!-- Submit Button -->
          <button type="submit" class="w-full bg-red-600 text-white py-3 rounded-lg font-bold text-lg hover:bg-red-700">
            <i class="fas fa-check-circle mr-2"></i> Xác Nhận Đơn Hàng
          </button>
        </form>
      </div>

      <!-- Order Summary -->
      <div class="lg:col-span-1">
        <div class="bg-white rounded-lg shadow p-6 sticky top-24">
          <h3 class="text-2xl font-bold mb-6">Tóm Tắt Đơn Hàng</h3>

          <div class="space-y-4 mb-6 max-h-80 overflow-y-auto">
            <% if (cartItems && cartItems.length > 0) { %>
              <% cartItems.forEach(item => { %>
                <div class="flex justify-between pb-4 border-b">
                  <div>
                    <p class="font-bold line-clamp-2"><%= item.name %></p>
                    <p class="text-sm text-gray-600">Qty: <%= item.quantity %></p>
                  </div>
                  <p class="font-bold"><%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(item.itemTotal) %></p>
                </div>
              <% }) %>
            <% } %>
          </div>

          <div class="space-y-4 pb-6 border-b">
            <div class="flex justify-between">
              <span>Subtotal:</span>
              <span><%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(total) %></span>
            </div>
            <div class="flex justify-between">
              <span>Shipping:</span>
              <span class="text-green-600 font-bold">Free</span>
            </div>
            <div class="flex justify-between">
              <span>Tax (10%):</span>
              <span><%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(total * 0.1) %></span>
            </div>
          </div>

          <div class="flex justify-between text-2xl font-bold">
            <span>Total:</span>
            <span class="text-red-600"><%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(total * 1.1) %></span>
          </div>

          <p class="text-sm text-gray-600 mt-4">
            <i class="fas fa-lock mr-2"></i> Your payment information is secure and encrypted.
          </p>
        </div>
      </div>
    </div>
  </div>

  <%- include('../partials/footer') %>
</body>
</html>
