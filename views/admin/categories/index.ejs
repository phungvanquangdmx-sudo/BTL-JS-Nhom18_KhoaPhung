<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quản Lý Danh Mục - TechStore</title>
  <link rel="icon" type="image/png" href="/images/favicon.png">
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-gray-50">
  <%- include('../../partials/navbar') %>

  <div class="max-w-3xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold mb-8">Quản Lý Danh Mục</h1>

    <!-- Add Category Form -->
    <div class="bg-white rounded-lg shadow p-8 mb-8">
      <h2 class="text-2xl font-bold mb-4">Thêm Danh Mục Mới</h2>
      <form action="/admin/categories/add" method="POST" class="space-y-4">
        <div>
          <label class="block font-bold mb-2">Tên Danh Mục</label>
          <input type="text" 
                 name="name" 
                 placeholder="iPhone"
                 class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-red-500"
                 required>
        </div>

        <div>
          <label class="block font-bold mb-2">Mô Tả</label>
          <textarea name="description" 
                    placeholder="Mô tả danh mục..."
                    class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-red-500"></textarea>
        </div>

        <button type="submit" class="bg-red-600 text-white px-6 py-2 rounded-lg hover:bg-red-700 font-bold">
          Thêm Danh Mục
        </button>
      </form>
    </div>

    <!-- Categories List -->
    <div class="bg-white rounded-lg shadow overflow-hidden">
      <table class="w-full">
        <thead class="bg-gray-100 border-b">
          <tr>
            <th class="px-6 py-3 text-left font-bold">ID</th>
            <th class="px-6 py-3 text-left font-bold">Tên</th>
            <th class="px-6 py-3 text-left font-bold">Mô Tả</th>
            <th class="px-6 py-3 text-left font-bold">Hành Động</th>
          </tr>
        </thead>
        <tbody>
          <% if (categories && categories.length > 0) { %>
            <% categories.forEach(category => { %>
              <tr class="border-b hover:bg-gray-50">
                <td class="px-6 py-3">#<%= category.id %></td>
                <td class="px-6 py-3 font-bold"><%= category.name %></td>
                <td class="px-6 py-3">
                  <% if (category.description) { %>
                    <%= category.description.substring(0, 50) %>...
                  <% } else { %>
                    <span class="text-gray-500">-</span>
                  <% } %>
                </td>
                <td class="px-6 py-3">
                  <a href="/admin/categories/delete/<%= category.id %>" class="text-red-600 hover:text-red-800" onclick="return confirm('Bạn có chắc chắn không?')">
                    <i class="fas fa-trash"></i> Xóa
                  </a>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="4" class="px-6 py-3 text-center text-gray-600">Không tìm thấy danh mục nào</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</body>
</html>
