<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Đơn Hàng - TechStore</title>
  <link rel="icon" type="image/png" href="/images/favicon.png">
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-gray-50">
  <%- include('../../partials/navbar') %>
   <!-- Flash Messages -->
  <% if (messages && messages.success && messages.success.length > 0) { %>
    <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded m-4">
      <% messages.success.forEach(msg => { %>
        <p><%= msg %></p>
      <% }) %>
    </div>
  <% } %>

  <% if (messages && messages.error && messages.error.length > 0) { %>
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded m-4">
      <% messages.error.forEach(msg => { %>
        <p><%= msg %></p>
      <% }) %>
    </div>
  <% } %>

  <div class="max-w-7xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold mb-8">Đơn Hàng</h1>

    <% if (orders && orders.length > 0) { %>
      <div class="space-y-4">
        <% orders.forEach(order => { %>
          <div class="bg-white rounded-lg shadow p-6">
            <div class="flex justify-between items-start mb-4">
              <div>
                <p class="text-sm text-gray-600">Order #<%= order.id %></p>
                <p class="text-sm text-gray-600">User: <%= order.user_id %></p>
                <p class="text-2xl font-bold"><%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(order.total_price) %></p>
              </div>
              <div class="text-right">
                <p class="text-sm text-gray-600"><%= new Date(order.created_at).toLocaleDateString() %></p>
                <span class="inline-block px-3 py-1 rounded-full text-white font-bold <%= order.status === 'completed' ? 'bg-green-500' : order.status === 'pending' ? 'bg-yellow-500' : 'bg-red-500' %>">
                  <%= order.status.charAt(0).toUpperCase() + order.status.slice(1) %>
                </span>
              </div>
            </div>

            <a href="/admin/orders/<%= order.id %>" class="inline-block bg-red-600 text-white px-6 py-2 rounded hover:bg-red-700">
              Xem Chi Tiết
            </a>
          </div>
        <% }) %>
      </div>

      <!-- Pagination -->
      <% if (totalPages > 1) { %>
        <div class="flex justify-center space-x-2 mt-8">
          <% if (currentPage > 1) { %>
            <a href="?page=<%= currentPage - 1 %>" class="px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700">
              Trước
            </a>
          <% } %>

          <% for (let i = 1; i <= totalPages; i++) { %>
            <a href="?page=<%= i %>" 
               class="px-4 py-2 rounded <%= i === currentPage ? 'bg-red-600 text-white' : 'bg-white border border-gray-300 hover:bg-gray-100' %>">
              <%= i %>
            </a>
          <% } %>

          <% if (currentPage < totalPages) { %>
            <a href="?page=<%= currentPage + 1 %>" class="px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700">
              Tiếp Theo
            </a>
          <% } %>
        </div>
      <% } %>
    <% } else { %>
      <div class="text-center py-16">
        <i class="fas fa-box-open text-6xl text-gray-300 mb-4"></i>
        <h2 class="text-3xl font-bold text-gray-800 mb-4">Chưa Có Đơn Hàng</h2>
        <p class="text-gray-600 mb-8">Khách hàng chưa đặt đơn nào</p>
        <a href="/admin/dashboard" class="inline-block bg-red-600 text-white px-8 py-3 rounded-lg font-bold hover:bg-red-700">
          Đến dashboard
        </a>
      </div>
    <% } %>
  </div>

  <%- include('../../partials/footer') %>
</body>
</html>
