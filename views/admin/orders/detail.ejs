<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Order #<%= order.id %> - TechStore</title>
  <link rel="icon" type="image/png" href="/images/favicon.png">
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-gray-50">
  <%- include('../../partials/navbar') %>
  

  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="mb-8">
      <a href="/admin/orders" class="text-red-600 hover:underline">← Quay Lại Đơn Hàng</a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Order Details -->
      <div class="md:col-span-2 space-y-6">
        <!-- Order Status -->
        <div class="bg-white rounded-lg shadow p-6">
          <div class="flex justify-between items-start mb-4">
            <div>
              <h1 class="text-3xl font-bold">Đơn #<%= order.id %></h1>
              <h2 class="text-lg text-gray-600">Người Đặt #<%= order.user_id %></h2>
              <p class="text-gray-600">Đặt ngày <%= new Date(order.created_at).toLocaleDateString() %></p>
            </div>
            <span class="inline-block px-4 py-2 rounded-full text-white font-bold <%= order.status === 'completed' ? 'bg-green-500' : order.status === 'pending' ? 'bg-yellow-500' : 'bg-red-500' %>">
              <%= order.status.charAt(0).toUpperCase() + order.status.slice(1) %>
            </span>
          </div>
        </div>

        <!-- Order Items -->
        <div class="bg-white rounded-lg shadow p-6">
          <h2 class="text-2xl font-bold mb-6">Các Mặt Hàng Đã Đặt</h2>

          <div class="space-y-4">
            <% if (items && items.length > 0) { %>
              <% items.forEach(item => { %>
                <div class="flex justify-between items-start pb-4 border-b">
                  <div>
                    <h3 class="font-bold"><%= item.name %></h3>
                    <p class="text-sm text-gray-600">SKU: #<%= item.product_id %></p>
                  </div>
                  <div class="text-right">
                    <p class="text-sm text-gray-600">Số Lượng: <%= item.quantity %></p>
                    <p class="font-bold"><%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(item.price) %></p>
                  </div>
                </div>
              <% }) %>
            <% } %>
          </div>
        </div>

        <!-- Shipping Address -->
        <div class="bg-white rounded-lg shadow p-6">
          <h2 class="text-2xl font-bold mb-4">Địa Chỉ Giao Hàng</h2>
          <p class="text-gray-700"><%= order.shipping_address %></p>
        </div>
      </div>

      <!-- Order Summary -->
      <div class="md:col-span-1">
        <div class="bg-white rounded-lg shadow p-6 sticky top-24">
          <h3 class="text-2xl font-bold mb-6">Tóm Tắt Đơn Hàng</h3>

          <div class="space-y-4 pb-6 border-b">
            <div class="flex justify-between">
              <span>Tổng Phụ:</span>
              <span><%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(order.total_price / 1.1) %></span>
            </div>
            <div class="flex justify-between">
              <span>Vận Chuyển:</span>
              <span class="text-green-600 font-bold">Miễn Phí</span>
            </div>
            <div class="flex justify-between">
              <span>Thuế (10%):</span>
              <span><%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(order.total_price / 1.1 * 0.1) %></span>
            </div>
          </div>

          <div class="flex justify-between text-2xl font-bold py-6">
            <span>Tổng Cộng:</span>
            <span class="text-red-600"><%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(order.total_price) %></span>
          </div>

          <div class="space-y-3">
            
            <a href="/admin/dashboard" class="block w-full bg-gray-200 text-gray-800 py-2 rounded hover:bg-gray-300 font-bold text-center">
                Quay Lại Dashboard
            </a>
            <form action="/admin/orders/<%= order.id %>/cancel" method="POST">
              <button type="submit" class="w-full bg-gray-200 text-gray-800 py-2 rounded hover:bg-gray-300 font-bold" onclick="return confirm('Bạn có chắc chắn muốn hủy đơn hàng này?');">
                Hủy Đơn Hàng
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%- include('../../partials/footer') %>
</body>
</html>
