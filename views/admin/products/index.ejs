<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quản Lý Sản Phẩm - TechStore</title>
  <link rel="icon" type="image/png" href="/images/favicon.png">
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-gray-50">
  <%- include('../../partials/navbar') %>

  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="flex justify-between items-center mb-8">
      <h1 class="text-4xl font-bold">Quản Lý Sản Phẩm</h1>
      <a href="/admin/products/add" class="bg-red-600 text-white px-6 py-3 rounded-lg hover:bg-red-700">
        <i class="fas fa-plus mr-2"></i> Thêm Sản Phẩm
      </a>
    </div>

    <!-- Search Bar -->
    <div class="mb-8">
      <form method="GET" action="/admin/products" class="flex gap-2">
        <input 
          type="text" 
          name="search" 
          placeholder="Tìm kiếm sản phẩm theo tên..." 
          value="<% if (typeof searchQuery !== 'undefined') { %><%= searchQuery %><% } %>"
          class="flex-1 px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-600"
        >
        <button 
          type="submit" 
          class="bg-red-600 text-white px-6 py-2 rounded-lg hover:bg-red-700 transition flex items-center space-x-2"
        >
          <i class="fas fa-search"></i>
          <span>Tìm kiếm</span>
        </button>
        <% if (typeof searchQuery !== 'undefined' && searchQuery) { %>
          <a 
            href="/admin/products" 
            class="bg-gray-400 text-white px-6 py-2 rounded-lg hover:bg-gray-500 transition flex items-center space-x-2"
          >
            <i class="fas fa-times"></i>
            <span>Xóa</span>
          </a>
        <% } %>
      </form>
      <% if (typeof searchQuery !== 'undefined' && searchQuery) { %>
        <p class="text-gray-600 mt-2">
          Kết quả tìm kiếm cho "<strong><%= searchQuery %></strong>" 
          <% if (products && products.length > 0) { %>
            - Tìm thấy <%= products.length %> sản phẩm
          <% } else { %>
            - Không tìm thấy sản phẩm
          <% } %>
        </p>
      <% } %>
    </div>

    <% if (products && products.length > 0) { %>
      <div class="bg-white rounded-lg shadow overflow-hidden">
        <table class="w-full">
          <thead class="bg-gray-100 border-b">
            <tr>
              <th class="px-6 py-3 text-left font-bold">ID</th>
              <th class="px-6 py-3 text-left font-bold">Tên</th>
              <th class="px-6 py-3 text-left font-bold">Giá</th>
              <th class="px-6 py-3 text-left font-bold">Giảm Giá</th>
              <th class="px-6 py-3 text-left font-bold">Kho Hàng</th>
              <th class="px-6 py-3 text-left font-bold">Hành Động</th>
            </tr>
          </thead>
          <tbody>
            <% products.forEach(product => { %>
              <tr class="border-b hover:bg-gray-50">
                <td class="px-6 py-3">#<%= product.id %></td>
                <td class="px-6 py-3 font-bold"><%= product.name %></td>
                <td class="px-6 py-3"><% const formatVND = (value) => new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(value); %><%= formatVND(parseFloat(product.price)) %></td>
                <td class="px-6 py-3">
                  <% if (product.discount_percent > 0) { %>
                    <span class="bg-red-100 text-red-800 px-3 py-1 rounded font-bold">
                      -<%= product.discount_percent %>%
                    </span>
                  <% } else { %>
                    <span class="text-gray-500">-</span>
                  <% } %>
                </td>
                <td class="px-6 py-3">
                  <% if (product.stock > 0) { %>
                    <span class="text-green-600 font-bold"><%= product.stock %></span>
                  <% } else { %>
                    <span class="text-red-600 font-bold">Hết Hàng</span>
                  <% } %>
                </td>
                <td class="px-6 py-3">
                  <div class="flex space-x-2">
                    <a href="/admin/products/edit/<%= product.id %>" class="text-blue-600 hover:text-blue-800">
                      <i class="fas fa-edit"></i> Chỉnh Sửa
                    </a>
                    <a href="/admin/products/delete/<%= product.id %>" class="text-red-600 hover:text-red-800" onclick="return confirm('Are you sure?')">
                      <i class="fas fa-trash"></i> Delete
                    </a>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <% if (totalPages > 1) { %>
        <div class="flex justify-center space-x-2 mt-8">
          <% if (currentPage > 1) { %>
            <a href="?page=<%= currentPage - 1 %><% if (typeof searchQuery !== 'undefined' && searchQuery) { %>&search=<%= encodeURIComponent(searchQuery) %><% } %>" class="px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700">
              Previous
            </a>
          <% } %>

          <% for (let i = 1; i <= totalPages; i++) { %>
            <a href="?page=<%= i %><% if (typeof searchQuery !== 'undefined' && searchQuery) { %>&search=<%= encodeURIComponent(searchQuery) %><% } %>" 
               class="px-4 py-2 rounded <%= i === currentPage ? 'bg-red-600 text-white' : 'bg-white border border-gray-300 hover:bg-gray-100' %>">
              <%= i %>
            </a>
          <% } %>

          <% if (currentPage < totalPages) { %>
            <a href="?page=<%= currentPage + 1 %><% if (typeof searchQuery !== 'undefined' && searchQuery) { %>&search=<%= encodeURIComponent(searchQuery) %><% } %>" class="px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700">
              Next
            </a>
          <% } %>
        </div>
      <% } %>
    <% } else { %>
      <div class="text-center py-12 bg-white rounded-lg shadow">
        <i class="fas fa-box-open text-6xl text-gray-300 mb-4"></i>
        <p class="text-xl text-gray-600">No products found</p>
      </div>
    <% } %>
  </div>
</body>
</html>
