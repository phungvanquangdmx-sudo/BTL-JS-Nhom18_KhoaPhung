<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Bảng Điều Khiển Admin - TechStore</title>
  <link rel="icon" type="image/png" href="/images/favicon.png">
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-gray-50">
  <%- include('../partials/navbar') %>

  <div class="max-w-7xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold mb-8">Bảng Điều Khiển Admin</h1>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
      <!-- Stats Cards -->
      <div class="bg-white rounded-lg shadow p-6">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-gray-600 text-sm font-bold">Tổng Sản Phẩm</p>
            <p class="text-3xl font-bold"><%=productTotal%></p>
          </div>
          <i class="fas fa-box text-4xl text-red-600 opacity-20"></i>
        </div>
      </div>

      <div class="bg-white rounded-lg shadow p-6">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-gray-600 text-sm font-bold">Tổng Đơn Hàng</p>
            <p class="text-3xl font-bold"><%=orderTotal%></p>
          </div>
          <i class="fas fa-shopping-cart text-4xl text-blue-600 opacity-20"></i>
        </div>
      </div>

      <div class="bg-white rounded-lg shadow p-6">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-gray-600 text-sm font-bold">Tổng Doanh Thu</p>
            <p class="text-3xl font-bold">$0</p>
          </div>
          <i class="fas fa-dollar-sign text-4xl text-green-600 opacity-20"></i>
        </div>
      </div>

      <div class="bg-white rounded-lg shadow p-6">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-gray-600 text-sm font-bold">Tổng Người Dùng</p>
            <p class="text-3xl font-bold">0</p>
          </div>
          <i class="fas fa-users text-4xl text-orange-600 opacity-20"></i>
        </div>
      </div>
    </div>

    <!-- Management Links -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <a href="/admin/products" class="bg-white rounded-lg shadow p-8 hover:shadow-lg transition text-center">
        <i class="fas fa-box text-5xl text-red-600 mb-4"></i>
        <h3 class="text-2xl font-bold mb-2">Sản Phẩm</h3>
        <p class="text-gray-600">Quản lý sản phẩm của bạn</p>
      </a>

      <a href="/admin/categories" class="bg-white rounded-lg shadow p-8 hover:shadow-lg transition text-center">
        <i class="fas fa-list text-5xl text-blue-600 mb-4"></i>
        <h3 class="text-2xl font-bold mb-2">Danh Mục</h3>
        <p class="text-gray-600">Quản lý danh mục</p>
      </a>

      <a href="/admin/orders" class="bg-white rounded-lg shadow p-8 hover:shadow-lg transition text-center">
        <i class="fas fa-shopping-cart text-5xl text-green-600 mb-4"></i>
        <h3 class="text-2xl font-bold mb-2">Đơn Hàng</h3>
        <p class="text-gray-600">Xem tất cả đơn hàng</p>
      </a>
    </div>
  </div>
</body>
</html>
