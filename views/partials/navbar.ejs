<nav class="bg-white shadow-lg sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 py-4">
    <div class="flex justify-between items-center">
      <!-- Logo -->
      <div class="flex items-center space-x-2">
        <img src="/images/logoStore.png" alt="TechStore Logo" class="h-8">
        <a href="/" class="text-2xl font-bold text-gray-800">TechStore</a>
      </div>

      <!-- Search Bar -->
      <div class="hidden md:flex flex-1 mx-8">
        <form action="/products/search" method="GET" class="w-full">
          <div class="flex">
            <input 
              type="text" 
              name="query" 
              placeholder="Tìm kiếm sản phẩm..." 
              class="flex-1 px-4 py-2 border border-gray-300 rounded-l-lg focus:outline-none focus:border-red-500"
              required
            >
            <button type="submit" class="bg-red-600 text-white px-6 py-2 rounded-r-lg hover:bg-red-700">
              <i class="fas fa-search"></i>
            </button>
          </div>
        </form>
      </div>

      <!-- Right Menu -->
      <div class="flex items-center space-x-6">
        <!-- Cart -->
        <a href="/cart" class="relative text-gray-700 hover:text-red-600">
          <i class="fas fa-shopping-cart text-2xl"></i>
          <% if (cartCount > 0) { %>
            <span class="absolute -top-2 -right-2 bg-red-500 text-white text-xs rounded-full w-5 h-5 flex items-center justify-center"><%= cartCount %></span>
          <% } %>
        </a>

        <!-- Auth Links -->
        <% if (userId) { %>
          <div class="relative group">
            <button class="text-gray-700 hover:text-red-600 flex items-center space-x-2">
              <i class="fas fa-user-circle text-2xl"></i>
              <span class="hidden md:inline"><%= userName %></span>
            </button>
            <div class="hidden group-hover:block absolute right-0 bg-white shadow-lg rounded-lg p-2 w-48">
              <a href="/orders" class="block px-4 py-2 text-gray-700 hover:bg-red-100 rounded">
                <i class="fas fa-box mr-2"></i> Đơn Hàng Của Tôi
              </a>
              <% if (isAdmin) { %>
                <a href="/admin/dashboard" class="block px-4 py-2 text-gray-700 hover:bg-red-100 rounded">
                  <i class="fas fa-cog mr-2"></i> Bảng Điều khiển Admin
                </a>
              <% } %>
              <a href="/auth/logout" class="block px-4 py-2 text-gray-700 hover:bg-red-100 rounded">
                <i class="fas fa-sign-out-alt mr-2"></i> Đăng Xuất
              </a>
            </div>
          </div>
        <% } else { %>
          <a href="/auth/login" class="bg-red-600 text-white px-4 py-2 rounded-lg hover:bg-red-700 transition flex items-center space-x-2 font-medium">
            <i class="fas fa-user"></i>
            <span>Đăng Nhập</span>
          </a>
        <% } %>
      </div>
    </div>

    <!-- Categories Menu -->
    <div class="hidden md:flex mt-4 space-x-6 border-t pt-4">
      <a href="/products" class="text-gray-700 hover:text-red-600 font-medium">Tất Cả Sản Phẩm</a>
      <% if (typeof categories !== 'undefined' && categories.length > 0) { %>
        <% categories.forEach(cat => { %>
          <a href="/products/category/<%= cat.id %>" class="text-gray-700 hover:text-red-600 font-medium">
            <%= cat.name %>
          </a>
        <% }) %>
      <% } %>
    </div>
  </div>
</nav>
