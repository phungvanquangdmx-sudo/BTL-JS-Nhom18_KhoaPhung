<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Lỗi Máy Chủ - TechStore</title>
  <link rel="icon" type="image/png" href="/images/favicon.png">
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-gray-50">
  <%- include('./partials/navbar') %>

  <div class="min-h-screen flex items-center justify-center px-4">
    <div class="text-center">
      <h1 class="text-8xl font-bold text-red-600 mb-4">500</h1>
      <h2 class="text-4xl font-bold text-gray-800 mb-4">Lỗi Máy Chủ</h2>
      <p class="text-xl text-gray-600 mb-8">Có vấn đề xảy ra. Vui lòng thử lại sau.</p>
      
      <% if (error && process.env.NODE_ENV === 'development') { %>
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-8 text-left">
          <p class="font-bold mb-2">Chi Tiết Lỗi:</p>
          <code class="block text-sm"><%= error %></code>
        </div>
      <% } %>
      
      <div class="space-x-4">
        <a href="/" class="inline-block bg-red-600 text-white px-8 py-3 rounded-lg hover:bg-red-700">
          Về Trang Chủ
        </a>
        <a href="/products" class="inline-block bg-gray-200 text-gray-800 px-8 py-3 rounded-lg hover:bg-gray-300">
          Mua Sắm Sản Phẩm
        </a>
      </div>
    </div>
  </div>

  <%- include('./partials/footer') %>
</body>
</html>
