<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Giỏ Hàng - TechStore</title>
  <link rel="icon" type="image/png" href="/images/favicon.png">
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
</head>
<body class="bg-gray-50">
  <%- include('../partials/navbar') %>

  <div class="max-w-7xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold mb-8">Giỏ Hàng</h1>

    <% if (cartItems && cartItems.length > 0) { %>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Cart Items -->
        <div class="lg:col-span-2 space-y-4">
          <% cartItems.forEach(item => { %>
            <div class="bg-white rounded-lg shadow p-6 flex gap-6">
              <!-- Product Image -->
              <div class="w-24 h-24 bg-gray-200 rounded flex-shrink-0">
                <img src="<% if (item.image && item.image !== 'products/default.jpg') { %>/uploads/<%= item.image %><% } else { %>https://via.placeholder.com/100x100?text=<%= item.name.substring(0, 5) %><% } %>" 
                     alt="<%= item.name %>" 
                     class="w-full h-full object-cover rounded">
              </div>

              <!-- Product Details -->
              <div class="flex-1">
                <h3 class="text-lg font-bold"><%= item.name %></h3>
                <p class="text-gray-600 text-sm mb-2"><%= item.category_name %></p>
                
                <div class="mb-4">
                  <span class="text-red-600 font-bold text-lg"><%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(item.discountedPrice) %></span>
                  <% if (item.discount_percent > 0) { %>
                    <span class="text-gray-400 line-through ml-2"><%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(item.price) %></span>
                  <% } %>
                </div>

                <!-- Quantity Control -->
                <div class="flex items-center space-x-2">
                  <button onclick="updateQuantity('<%= item.id %>', '<%= item.quantity - 1 %>')" class="bg-gray-200 px-3 py-1 rounded hover:bg-gray-300">
                    <i class="fas fa-minus"></i>
                  </button>
                  <span class="w-8 text-center"><%= item.quantity %></span>
                  <button onclick="updateQuantity('<%= item.id %>', '<%= item.quantity + 1 %>')" class="bg-gray-200 px-3 py-1 rounded hover:bg-gray-300">
                    <i class="fas fa-plus"></i>
                  </button>
                </div>
              </div>

              <!-- Price & Remove -->
              <div class="text-right">
                <p class="text-xl font-bold text-red-600 mb-4"><%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(item.itemTotal) %></p>
                <button onclick="removeFromCart('<%= item.id %>')" class="text-red-600 hover:text-red-800">
                  <i class="fas fa-trash-alt"></i> Xóa
                </button>
              </div>
            </div>
          <% }) %>
        </div>

        <!-- Order Summary -->
        <div class="lg:col-span-1">
          <div class="bg-white rounded-lg shadow p-6 sticky top-24">
            <h3 class="text-2xl font-bold mb-6">Tóm Tắt Đơn Hàng</h3>

            <div class="space-y-4 mb-6 pb-6 border-b">
              <div class="flex justify-between">
                <span>Tổng Phụ:</span>
                <span><%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(total) %></span>
              </div>
              <div class="flex justify-between">
                <span>Vận Chuyển:</span>
                <span class="text-green-600 font-bold">Miễn Phí</span>
              </div>
              <div class="flex justify-between">
                <span>Thuế:</span>
                <span><%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(total * 0.1) %></span>
              </div>
            </div>

            <div class="flex justify-between text-2xl font-bold mb-6">
              <span>Tổng Cộng:</span>
              <span class="text-red-600"><%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(total * 1.1) %></span>
            </div>

            <a href="/checkout" class="block w-full bg-red-600 text-white py-3 rounded-lg font-bold text-center hover:bg-red-700 mb-3">
              <i class="fas fa-credit-card mr-2"></i> Thanh Toán
            </a>

            <a href="/products" class="block w-full bg-gray-200 text-gray-800 py-3 rounded-lg font-bold text-center hover:bg-gray-300">
              Tiếp Tục Mua Hàng
            </a>

            <button onclick="clearCart()" class="w-full mt-4 text-red-600 hover:text-red-800 font-bold">
              <i class="fas fa-trash"></i> Xóa Giỏ Hàng
            </button>
          </div>
        </div>
      </div>
    <% } else { %>
      <!-- Empty Cart -->
      <div class="text-center py-16">
        <i class="fas fa-shopping-cart text-6xl text-gray-300 mb-4"></i>
        <h2 class="text-3xl font-bold text-gray-800 mb-4">Giỏ Hàng Của Bạn Trống</h2>
        <p class="text-gray-600 mb-8">Bắt đầu mua sắm để điền vào giỏ hàng của bạn!</p>
        <a href="/products" class="inline-block bg-red-600 text-white px-8 py-3 rounded-lg font-bold hover:bg-red-700">
          Tiếp Tục Mua Hàng
        </a>
      </div>
    <% } %>
  </div>

  <%- include('../partials/footer') %>

  <script>
    async function updateQuantity(productId, newQuantity) {
      if (newQuantity <= 0) {
        removeFromCart(productId);
        return;
      }

      try {
        const response = await axios.post('/cart/update', {
          productId: productId,
          quantity: newQuantity
        });
        if (response.data.success) {
          location.reload();
        }
      } catch (error) {
        console.error('Error:', error);
      }
    }

    async function removeFromCart(productId) {
      try {
        const response = await axios.post('/cart/remove', {
          productId: productId
        });
        if (response.data.success) {
          location.reload();
        }
      } catch (error) {
        console.error('Error:', error);
      }
    }

    async function clearCart() {
      if (!confirm('Bạn có chắc chắn muốn xóa giỏ hàng không?')) return;
      
      try {
        const response = await axios.post('/cart/clear');
        if (response.data.success) {
          location.reload();
        }
      } catch (error) {
        console.error('Error:', error);
      }
    }
  </script>
</body>
</html>
